# Local API environment — copy to `.env` and fill secrets.
# Never commit the real `.env` file.
# For local dev, DATABASE_URL must match docker-compose.yml defaults:
# postgresql://postgres:postgres@localhost:5432/sadaf_gold?schema=public

NODE_ENV=development

# PostgreSQL (docker-compose defaults)
POSTGRES_DB=sadaf_gold
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sadaf_gold?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sadaf_gold?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT (min 32 chars each)
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret-min-32-chars

# BrsApi market data
BRS_API_KEY=
BRS_BASE_URL=https://brsapi.ir
BRS_API_URL=https://api.brsapi.ir/Market/Gold_Currency.php
BRS_REQUEST_TIMEOUT_MS=8000
BRS_MAX_RETRIES=2

# Market sync + Redis cache
MARKET_SYNC_INTERVAL_MS=30000
MARKET_CACHE_TTL_SECONDS=45
MARKET_CACHE_STALE_SECONDS=300
MARKET_GOLD_CACHE_TTL_SECONDS=45
MARKET_CURRENCY_CACHE_TTL_SECONDS=60
MARKET_SYNC_LOCK_TTL_SECONDS=25

# Swagger (dev)
SWAGGER_ENABLED=true
