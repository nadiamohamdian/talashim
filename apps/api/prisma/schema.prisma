generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  ADMIN
}

enum ProductCategory {
  RING
  NECKLACE
  BRACELET
  COIN
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  FAILED
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  fullName      String
  role          Role           @default(CUSTOMER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  addresses     Address[]
  carts         Cart[]
  orders        Order[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  title      String
  recipient  String
  phone      String
  line1      String
  city       String
  state      String
  postalCode String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id               String          @id @default(cuid())
  slug             String          @unique
  title            String
  description      String
  seoDescription   String
  category         ProductCategory
  karat            Int
  weightGram       Decimal         @db.Decimal(10, 2)
  makingFeePercent Int
  priceToman       Int
  imageUrl         String
  featured         Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  inventoryItem    InventoryItem?
  cartItems        CartItem[]
  orderItems       OrderItem[]
}

model InventoryItem {
  id        String   @id @default(cuid())
  productId String   @unique
  quantity  Int
  reserved  Int      @default(0)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Cart {
  id         String      @id @default(cuid())
  userId     String?
  sessionKey String?     @unique
  status     CartStatus  @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      CartItem[]
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  quantity       Int
  unitPriceToman Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String?
  status        OrderStatus @default(PENDING)
  subtotalToman Int
  taxToman      Int
  totalToman    Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  payments      Payment[]
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  productId      String
  quantity       Int
  unitPriceToman Int
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  status      PaymentStatus @default(PENDING)
  provider    String
  reference   String?
  amountToman Int
  createdAt   DateTime      @default(now())
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model BlogCategory {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  createdAt DateTime   @default(now())
  posts     BlogPost[]
}

model BlogPost {
  id            String        @id @default(cuid())
  categoryId    String?
  slug          String        @unique
  title         String
  excerpt       String
  content       String
  coverImageUrl String
  publishedAt   DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  context   Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
