generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CUSTOMER
  SUPER_ADMIN
  SUPPORT
  ACCOUNTANT
  EDITOR
  WAREHOUSE
}

enum ProductCategory {
  RING
  NECKLACE
  BRACELET
  EARRING
  COIN
  WEDDING_RING
}

enum CartStatus {
  ACTIVE
  CHECKED_OUT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  AWAITING_RECEIPT
  RECEIPT_SUBMITTED
  AUTHORIZED
  PAID
  FAILED
  REJECTED
}

enum DiscountType {
  PERCENT
  FIXED_AMOUNT
}

enum InventoryMovementType {
  INITIAL
  ADJUSTMENT
  RESERVATION
  RELEASE
  ORDER_FULFILLMENT
}

enum ProductReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  fullName         String
  firstName        String?
  lastName         String?
  nationalId       String?
  phone                  String?           @unique
  requiresPasswordSetup  Boolean           @default(false)
  role             Role              @default(CUSTOMER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  addresses        Address[]
  carts            Cart[]
  orders           Order[]
  refreshTokens    RefreshToken[]
  auditLogs        AuditLog[]
  ledgerAccounts   LedgerAccount[]
  walletTransactions WalletTransaction[]
  walletAuditLogs  WalletAuditLog[]
  goldTradeOrders    GoldTradeOrder[]
  goldTradeAuditLogs GoldTradeAuditLog[]
  kycVerification    KycVerification?
  kycReviews         KycVerification[] @relation("KycReviewer")
  wishlistItems      WishlistItem[]
  mediaAssets        MediaAsset[]
  goldPriceOverrides GoldPriceOverride[]
  inventoryMovements InventoryMovement[]
  staffNotifications StaffNotification[] @relation("StaffNotificationRecipient")
  staffTicketsCreated StaffTicket[]       @relation("StaffTicketCreator")
  staffTicketsClosed  StaffTicket[]       @relation("StaffTicketCloser")
  staffTicketMessages StaffTicketMessage[]
  productReviews      ProductReview[]
  createdCoupons      DiscountCoupon[] @relation("CouponCreator")
  updatedCoupons      DiscountCoupon[] @relation("CouponUpdater")
  couponUsages      CouponUsage[]

  @@index([phone])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  title      String
  recipient  String
  phone      String
  line1      String
  city       String
  state      String
  postalCode String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]
}

model Product {
  id                String          @id @default(cuid())
  sku               String          @unique
  slug              String          @unique
  title             String
  description       String
  seoDescription    String
  seoTitle          String?
  seoKeywords       String?
  ogImageUrl        String?
  seoCanonicalPath  String?
  seoNoIndex        Boolean         @default(false)
  category          ProductCategory
  karat             Int
  weightGram        Decimal         @db.Decimal(10, 2)
  makingFeePercent  Int
  priceToman        BigInt
  discountPercent   Int?
  discountStartsAt  DateTime?
  discountEndsAt    DateTime?
  imageUrl          String
  hoverImageUrl     String
  featured          Boolean         @default(false)
  pdpConfig         Json?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  inventoryItem     InventoryItem?
  cartItems         CartItem[]
  orderItems        OrderItem[]
  wishlistItems     WishlistItem[]
  videos            ProductVideo[]
  images            ProductImage[]
  variants          ProductVariant[]
  inventoryMoves    InventoryMovement[]
  bannerLinks       CmsBannerProduct[]
  lensVideoLinks    CmsLensVideoProduct[]
  reviews           ProductReview[]

  @@index([discountPercent, discountEndsAt])
}

model CatalogCategoryPage {
  id              String           @id @default(cuid())
  slug            String           @unique
  title           String
  subtitle        String?
  productCategory ProductCategory?
  heroImageUrls   String[]         @default([])
  filterConfig    Json
  sortOrder       Int              @default(0)
  isActive        Boolean          @default(true)
  seoTitle        String?
  seoDescription  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([isActive, sortOrder])
}

model ProductReview {
  id         String              @id @default(cuid())
  productId  String
  userId     String?
  authorName String?
  phone      String
  body       String
  rating     Int
  status     ProductReviewStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId, status, createdAt])
  @@index([phone, createdAt])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  alt       String   @default("")
  sortOrder Int      @default(0)
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVariant {
  id               String   @id @default(cuid())
  productId        String
  sku              String   @unique
  color            String?
  size             String?
  stone            String?
  priceToman       BigInt
  weightGram       Decimal? @db.Decimal(10, 2)
  makingFeePercent Int?
  imageUrl         String?
  quantity         Int      @default(0)
  sortOrder        Int      @default(0)
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model InventoryItem {
  id        String   @id @default(cuid())
  productId String   @unique
  quantity  Int
  reserved  Int      @default(0)
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model InventoryMovement {
  id             String                @id @default(cuid())
  productId      String
  actorId        String?
  type           InventoryMovementType
  quantityDelta  Int
  quantityBefore Int
  quantityAfter  Int
  reservedBefore Int                   @default(0)
  reservedAfter  Int                   @default(0)
  note           String?
  createdAt      DateTime              @default(now())
  product        Product               @relation(fields: [productId], references: [id], onDelete: Cascade)
  actor          User?                 @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
}

model ProductVideo {
  id           String   @id @default(cuid())
  productId    String?
  title        String
  videoUrl     String
  thumbnailUrl String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  product      Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([productId, sortOrder])
}

model Cart {
  id         String      @id @default(cuid())
  userId     String?
  sessionKey String?     @unique
  status     CartStatus  @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items      CartItem[]

  @@index([userId, status])
}

model CartItem {
  id             String   @id @default(cuid())
  cartId         String
  productId      String
  quantity       Int
  unitPriceToman BigInt
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  cart           Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
}

model Order {
  id                           String      @id @default(cuid())
  orderNumber                  String      @unique
  userId                       String?
  shippingAddressId            String?
  status                       OrderStatus @default(PENDING)
  subtotalToman                BigInt
  taxToman                     BigInt
  taxPercent                   Int?
  liveGoldPrice18PerGramToman  BigInt?
  isInsured                    Boolean     @default(false)
  insuranceFeeToman            BigInt      @default(0)
  totalToman                   BigInt
  invoiceFirstName             String?
  invoiceLastName              String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  shippingAddress   Address?    @relation(fields: [shippingAddressId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  couponId          String?
  couponCode        String?
  discountToman     BigInt      @default(0)
  coupon            DiscountCoupon? @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponUsages      CouponUsage[]

  @@index([userId, createdAt])
  @@index([userId, status])
}

model OrderItem {
  id                        String   @id @default(cuid())
  orderId                   String
  productId                 String
  quantity                  Int
  unitPriceToman            BigInt
  weightGram                Decimal? @db.Decimal(10, 2)
  karat                     Int?
  makingFeePercent          Int?
  liveGoldPricePerGramToman BigInt?
  metalValueToman           BigInt?
  wageToman                 BigInt?
  createdAt                 DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  status            PaymentStatus @default(PENDING)
  provider          String
  reference         String?
  amountToman       BigInt
  receiptUrl        String?
  receiptUploadedAt DateTime?
  reviewedAt        DateTime?
  reviewedById      String?
  rejectionReason   String?
  createdAt         DateTime      @default(now())
  order             Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model DiscountCoupon {
  id                     String       @id @default(cuid())
  code                   String       @unique
  title                  String
  description            String?
  isActive               Boolean      @default(true)
  startsAt               DateTime?
  expiresAt              DateTime?
  discountType           DiscountType
  discountValue          Decimal      @db.Decimal(12, 2)
  minimumOrderAmount     BigInt?
  maximumDiscountAmount  BigInt?
  usageLimitTotal        Int?
  usageLimitPerUser      Int?
  usedCount              Int          @default(0)
  isFirstPurchaseOnly    Boolean      @default(false)
  allowWithOtherCoupons  Boolean      @default(false)
  applicableCategories   ProductCategory[]
  applicableProducts     String[]
  excludedProducts       String[]
  excludedCategories     ProductCategory[]
  applicableUsers        String[]
  excludedUsers          String[]
  customerGroup          String?
  createdBy              String?
  updatedBy              String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  deletedAt              DateTime?
  creator                User?        @relation("CouponCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  updater                User?        @relation("CouponUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)
  usages                 CouponUsage[]
  orders                 Order[]

  @@index([isActive, startsAt, expiresAt])
  @@index([deletedAt])
}

model CouponUsage {
  id             String         @id @default(cuid())
  couponId       String
  userId         String
  orderId        String
  discountAmount BigInt
  usedAt         DateTime       @default(now())
  coupon         DiscountCoupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([couponId, usedAt])
  @@index([userId, usedAt])
  @@unique([couponId, userId, orderId])
}

enum StaffTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum StaffTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model StaffTicket {
  id           String              @id @default(cuid())
  ticketNumber String              @unique
  subject      String
  body         String
  status       StaffTicketStatus   @default(OPEN)
  priority     StaffTicketPriority @default(NORMAL)
  category     String              @default("general")
  createdById  String
  closedById   String?
  closedAt     DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  createdBy    User                @relation("StaffTicketCreator", fields: [createdById], references: [id], onDelete: Cascade)
  closedBy     User?               @relation("StaffTicketCloser", fields: [closedById], references: [id], onDelete: SetNull)
  messages     StaffTicketMessage[]

  @@index([createdById, createdAt])
  @@index([status, createdAt])
}

model StaffTicketMessage {
  id        String      @id @default(cuid())
  ticketId  String
  authorId  String
  body      String
  createdAt DateTime    @default(now())
  ticket    StaffTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

model BlogCategory {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  createdAt DateTime   @default(now())
  posts     BlogPost[]
}

model BlogPost {
  id            String        @id @default(cuid())
  categoryId    String?
  slug          String        @unique
  title         String
  excerpt       String
  content       String
  coverImageUrl String
  publishedAt   DateTime
  isPublished   Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  category      BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId, sortOrder])
  @@index([isPublished, publishedAt])
}

enum CmsBannerPlacement {
  HOME_HERO
  HOME_MID
  CATEGORY_TOP
  GLOBAL
}

enum CmsBannerStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CmsBannerLinkType {
  URL
  COLLECTION
}

model CmsBanner {
  id        String             @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkType  CmsBannerLinkType  @default(URL)
  linkUrl   String?
  placement CmsBannerPlacement @default(HOME_MID)
  sortOrder Int                @default(0)
  status    CmsBannerStatus    @default(DRAFT)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  products  CmsBannerProduct[]

  @@index([status, placement, sortOrder])
}

model CmsBannerProduct {
  id        String    @id @default(cuid())
  bannerId  String
  productId String
  sortOrder Int       @default(0)
  banner    CmsBanner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([bannerId, productId])
  @@index([bannerId, sortOrder])
}

model CmsHomepage {
  id        String   @id @default("default")
  hero      Json
  sections  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CmsStaticPage {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  content         String
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model CmsLensVideo {
  id           String               @id @default(cuid())
  title        String?
  videoUrl     String
  thumbnailUrl String?
  /** Editorial hero image for the lens-sets showcase stage */
  heroImageUrl String?
  /** Hotspot positions for product chips on the hero image (max 3) */
  hotspots     Json?
  sortOrder    Int                  @default(0)
  status       CmsBannerStatus      @default(DRAFT)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  products     CmsLensVideoProduct[]

  @@index([status, sortOrder])
}

model CmsLensVideoProduct {
  id           String       @id @default(cuid())
  lensVideoId  String
  productId    String
  sortOrder    Int          @default(0)
  lensVideo    CmsLensVideo @relation(fields: [lensVideoId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([lensVideoId, productId])
  @@index([lensVideoId, sortOrder])
}

model CmsSeoSettings {
  id                String   @id @default("default")
  siteTitle         String
  siteDescription   String
  defaultOgImageUrl String?
  robotsIndex       Boolean  @default(true)
  googleAnalyticsId String?
  extraMeta         Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CmsAboutPage {
  id            String   @id @default("default")
  meta          Json
  copy          Json
  decorImageUrl String
  values        Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PlatformSettings {
  id           String   @id @default("default")
  general      Json
  commerce     Json
  gold         Json
  featureFlags Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MediaAsset {
  id         String   @id @default(cuid())
  filename   String
  url        String
  mimeType   String
  sizeBytes  Int
  alt        String?
  folder     String   @default("general")
  uploadedBy String?
  createdAt  DateTime @default(now())
  uploader   User?    @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@index([folder, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  context   Json?
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
}

model RefreshToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum WalletAssetType {
  RIAL
  GOLD
}

enum LedgerAccountCategory {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum LedgerSide {
  DEBIT
  CREDIT
}

enum WalletTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  CONVERSION
  FEE
  ADJUSTMENT
  TRADE_BUY
  TRADE_SELL
}

enum WalletTransactionStatus {
  PENDING
  POSTED
  FAILED
  REVERSED
}

model LedgerAccount {
  id        String                @id @default(cuid())
  code      String                @unique
  name      String
  category  LedgerAccountCategory
  assetType WalletAssetType?
  userId    String?
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  user      User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)
  entries   LedgerEntry[]

  @@index([userId])
}

model WalletTransaction {
  id             String                  @id @default(cuid())
  reference      String                  @unique
  idempotencyKey String                  @unique
  type           WalletTransactionType
  status         WalletTransactionStatus @default(PENDING)
  description    String?
  userId         String?
  metadata       Json?
  postedAt       DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  user           User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  entries        LedgerEntry[]
  auditLogs      WalletAuditLog[]
  goldTradeOrder GoldTradeOrder?

  @@index([userId, createdAt])
}

model LedgerEntry {
  id            String            @id @default(cuid())
  transactionId String
  accountId     String
  side          LedgerSide
  assetType     WalletAssetType
  amount        Decimal           @db.Decimal(20, 6)
  createdAt     DateTime          @default(now())
  transaction   WalletTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  account       LedgerAccount     @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([accountId, createdAt])
  @@index([transactionId])
}

model WalletAuditLog {
  id            String             @id @default(cuid())
  transactionId String?
  actorId       String?
  action        String
  context       Json?
  createdAt     DateTime           @default(now())
  transaction   WalletTransaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  actor         User?              @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([transactionId])
  @@index([actorId, createdAt])
}

enum GoldPriceSource {
  PRIMARY
  FALLBACK
  MANUAL
}

model GoldPriceTick {
  id            String          @id @default(cuid())
  symbol        String          @default("XAU-IRR")
  karat         Int             @default(18)
  pricePerGram  Decimal         @db.Decimal(20, 2)
  buyPrice      Decimal         @db.Decimal(20, 2)
  sellPrice     Decimal         @db.Decimal(20, 2)
  spreadPercent Decimal         @db.Decimal(6, 4)
  source        GoldPriceSource
  providerName  String
  recordedAt    DateTime        @default(now())

  @@index([symbol, karat, recordedAt])
  @@index([recordedAt])
}

model PricingConfig {
  id                      String   @id @default("default")
  spreadPercent           Decimal  @db.Decimal(6, 4)
  tradeCommissionPercent  Decimal  @db.Decimal(6, 4)
  defaultMakingFeePercent Int      @default(10)
  refreshIntervalMs       Int      @default(30000)
  primaryProviderName     String   @default("brsapi")
  fallbackProviderName    String   @default("fallback-static")
  brsEnabled              Boolean  @default(true)
  updatedAt               DateTime @updatedAt
}

model GoldPriceOverride {
  id           String    @id @default(cuid())
  symbol       String    @default("XAU-IRR")
  karat        Int       @default(18)
  pricePerGram Decimal   @db.Decimal(20, 2)
  buyPrice     Decimal?  @db.Decimal(20, 2)
  sellPrice    Decimal?  @db.Decimal(20, 2)
  reason       String?
  isActive     Boolean   @default(true)
  expiresAt    DateTime?
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([symbol, karat, isActive])
  @@index([expiresAt])
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model KycVerification {
  id           String    @id @default(cuid())
  userId       String    @unique
  nationalId   String
  phone        String
  documentType String    @default("national_card")
  documentUrl  String?
  status       KycStatus @default(PENDING)
  reviewNote   String?
  reviewedById String?
  submittedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer     User?     @relation("KycReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, submittedAt])
}

enum GoldTradeSide {
  BUY
  SELL
}

enum GoldTradeStatus {
  PENDING
  FILLED
  FAILED
}

model GoldTradeOrder {
  id                  String           @id @default(cuid())
  orderNumber         String           @unique
  userId              String
  side                GoldTradeSide
  status              GoldTradeStatus  @default(PENDING)
  symbol              String           @default("XAU-IRR")
  karat               Int              @default(18)
  quantityGram        Decimal          @db.Decimal(20, 6)
  unitPriceToman      Decimal          @db.Decimal(20, 2)
  grossRial           Decimal          @db.Decimal(20, 2)
  commissionRial      Decimal          @db.Decimal(20, 2)
  netRial             Decimal          @db.Decimal(20, 2)
  commissionPercent   Decimal          @db.Decimal(6, 4)
  idempotencyKey      String           @unique
  walletTransactionId String?          @unique
  failureReason       String?
  createdAt           DateTime         @default(now())
  filledAt            DateTime?
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletTransaction   WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: SetNull)
  auditLogs           GoldTradeAuditLog[]

  @@index([userId, createdAt])
  @@index([userId, side, status])
}

model GoldTradeAuditLog {
  id        String         @id @default(cuid())
  orderId   String
  actorId   String?
  action    String
  context   Json?
  createdAt DateTime       @default(now())
  order     GoldTradeOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor     User?          @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([actorId, createdAt])
}

enum NotificationChannel {
  IN_APP
  SMS
  EMAIL
  PUSH
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}

enum NotificationRuleTrigger {
  ORDER_CREATED
  ORDER_PAID
  KYC_SUBMITTED
  KYC_APPROVED
  TRADE_FILLED
  LOW_STOCK
  MANUAL
}

model StaffNotification {
  id              String               @id @default(cuid())
  title           String
  body            String
  channel         NotificationChannel  @default(IN_APP)
  priority        NotificationPriority @default(NORMAL)
  category        String               @default("operational")
  targetRole      Role?
  recipientUserId String?
  readAt          DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())
  recipient       User?                @relation("StaffNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([recipientUserId, readAt])
  @@index([targetRole, readAt])
}

model NotificationTemplate {
  id        String              @id @default(cuid())
  key       String              @unique
  name      String
  channel   NotificationChannel
  subject   String?
  body      String
  isActive  Boolean             @default(true)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  rules     NotificationRule[]
  deliveries NotificationDelivery[]
}

model NotificationRule {
  id         String                  @id @default(cuid())
  name       String
  trigger    NotificationRuleTrigger
  templateId String
  channel    NotificationChannel
  isEnabled  Boolean                 @default(true)
  conditions Json?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  template   NotificationTemplate    @relation(fields: [templateId], references: [id], onDelete: Restrict)
  deliveries NotificationDelivery[]

  @@index([trigger, isEnabled])
}

model NotificationDelivery {
  id           String                     @id @default(cuid())
  templateId   String?
  ruleId       String?
  channel      NotificationChannel
  recipient    String
  status       NotificationDeliveryStatus @default(PENDING)
  title        String?
  body         String
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime                   @default(now())
  template     NotificationTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  rule         NotificationRule?          @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([channel, createdAt])
}

model StaffRolePermission {
  id         String   @id @default(cuid())
  role       Role
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@index([role])
}
