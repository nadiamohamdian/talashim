{
  "extends": "../../packages/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@sadafgold/ui": ["../../packages/ui/src/index.ts"],
      "@sadafgold/ui/*": ["../../packages/ui/src/*"],
      "@sadafgold/types": ["../../packages/types/src/index.ts"],
      "@sadafgold/types/*": ["../../packages/types/src/*"],
      "@sadafgold/shared": ["../../packages/shared/src/index.ts"],
      "@sadafgold/shared/*": ["../../packages/shared/src/*"],
      "@sadafgold/api-client": ["../../packages/api-client/src/index.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
