# Copy to .env before: docker compose up --build

NODE_ENV=development

NEXT_PUBLIC_APP_NAME=طلاشیم
NEXT_PUBLIC_ADMIN_APP_NAME=پنل مدیریت طلاشیم
NEXT_PUBLIC_API_BASE_URL=http://api.localhost:8080/api/v1

API_PORT=4000
API_PREFIX=api
API_VERSION=v1
WEB_URL=http://localhost:8080
ADMIN_URL=http://admin.localhost:8080
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:8080

POSTGRES_DB=sadaf_gold
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sadaf_gold?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/sadaf_gold?schema=public

REDIS_PORT=6379
REDIS_URL=redis://redis:6379

WORKER_NAME=pricing-sync
WORKER_CONCURRENCY=5

JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

NGINX_PORT=8080

# Optional hosts (add to C:\Windows\System32\drivers\etc\hosts):
# 127.0.0.1 admin.localhost
# 127.0.0.1 api.localhost
