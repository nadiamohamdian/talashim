# Copy to .env.production on the deployment server and fill all secrets.
# Never commit the real .env.production file.

NODE_ENV=production

# ── Domains (DNS must point to this server) ──────────────────────────────────
RETAIL_DOMAIN=retail.talashim.com
WHOLESALE_DOMAIN=wholesale.talashim.com
ADMIN_DOMAIN=admin.talashim.com
API_DOMAIN=api.talashim.com
CERT_NAME=talashim
LETSENCRYPT_EMAIL=ops@talashim.com

# ── Public URLs (used at Next.js build time and API CORS) ────────────────────
NEXT_PUBLIC_APP_NAME=طلاشیم
NEXT_PUBLIC_ADMIN_APP_NAME=پنل مدیریت طلاشیم
NEXT_PUBLIC_API_BASE_URL=https://api.talashim.com/api/v1
NEXT_PUBLIC_WS_BASE_URL=https://api.talashim.com
NEXT_PUBLIC_GOLD_TRADE_COMMISSION_PERCENT=0.5

WEB_URL=https://retail.talashim.com
ADMIN_URL=https://admin.talashim.com
CORS_ORIGINS=https://retail.talashim.com,https://wholesale.talashim.com,https://admin.talashim.com
COOKIE_DOMAIN=.talashim.com

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=4000
API_PREFIX=api
API_VERSION=v1
SWAGGER_ENABLED=false
TRUST_PROXY=true
LOG_LEVEL=log
COMPRESSION_ENABLED=true

THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_TTL_MS=300000
HTTP_CACHE_TTL_SECONDS=120

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=sadaf_gold
POSTGRES_USER=sadafgold
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://sadafgold:CHANGE_ME@postgres:5432/sadaf_gold?schema=public
DIRECT_DATABASE_URL=postgresql://sadafgold:CHANGE_ME@postgres:5432/sadaf_gold?schema=public

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME@redis:6379

# ── MinIO / object storage ───────────────────────────────────────────────────
MINIO_ROOT_USER=sadafgold
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=sadafgold
MINIO_USE_SSL=false

# ── Auth (min 32 chars each) ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ── Gold pricing / trading ─────────────────────────────────────────────────────
# BrsApi — live gold/currency (https://brsapi.ir/free-api-gold-currency-webservice/)
BRS_API_KEY=
BRS_BASE_URL=https://brsapi.ir
BRS_API_URL=https://api.brsapi.ir/Market/Gold_Currency.php
BRS_REQUEST_TIMEOUT_MS=8000
BRS_MAX_RETRIES=2
MARKET_SYNC_INTERVAL_MS=30000
MARKET_CACHE_TTL_SECONDS=45
MARKET_CACHE_STALE_SECONDS=300
MARKET_SYNC_LOCK_TTL_SECONDS=25
GOLD_PRICE_PRIMARY_URL=
GOLD_PRICE_REFRESH_MS=30000
GOLD_PRICE_CACHE_TTL_SECONDS=60
GOLD_SPREAD_PERCENT=1.5
GOLD_TRADE_COMMISSION_PERCENT=0.5
GOLD_TRADE_MIN_GRAM=0.01

# ── Worker ───────────────────────────────────────────────────────────────────
WORKER_NAME=pricing-sync
WORKER_CONCURRENCY=5

# ── Nginx / TLS ──────────────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
SSL_ENABLED=false

# ── Docker images (CI sets these; leave default for local prod build) ────────
# API_IMAGE=ghcr.io/your-org/sadafgold-api:latest
# WEB_IMAGE=ghcr.io/your-org/sadafgold-web:latest
# ADMIN_IMAGE=ghcr.io/your-org/sadafgold-admin:latest
# WORKER_IMAGE=ghcr.io/your-org/sadafgold-worker:latest
IMAGE_TAG=latest
ENV_FILE=.env.production
