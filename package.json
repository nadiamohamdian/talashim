{
  "name": "sadaf-gold",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=9.12.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @sadafgold/web dev",
    "dev:store": "pnpm --filter @sadafgold/web dev",
    "dev:admin": "pnpm --filter @sadafgold/admin dev",
    "dev:api": "pnpm --filter @sadafgold/api start:dev",
    "dev:worker": "pnpm --filter @sadafgold/worker start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf .turbo \"apps/*/.next\" \"apps/*/dist\" \"packages/*/dist\"",
    "prepare": "husky",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d",
    "docker:prod:ssl": "docker compose -f docker-compose.prod.yml -f docker-compose.ssl.yml --env-file .env.production up -d",
    "deploy": "bash scripts/deploy.sh",
    "deploy:health": "bash scripts/health-check.sh"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.6",
      "react-dom": "19.2.6",
      "typescript": "6.0.3"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "eslint-config-next": "catalog:",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "catalog:",
    "rimraf": "^6.0.1",
    "tailwindcss": "catalog:",
    "tsx": "^4.22.3",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "dependencies": {
    "@tanstack/react-query": "catalog:"
  }
}
