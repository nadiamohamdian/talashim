{
  "name": "sadaf-gold",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @gold/web dev",
    "dev:admin": "pnpm --filter @gold/admin dev",
    "dev:api": "pnpm --filter @gold/api start:dev",
    "dev:worker": "pnpm --filter @gold/worker start:dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "rimraf .turbo \"apps/*/.next\" \"apps/*/dist\" \"packages/*/dist\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@eslint/js": "^9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10",
    "globals": "^16",
    "husky": "^9",
    "lint-staged": "^16",
    "prettier": "^3",
    "rimraf": "^6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  }
}
