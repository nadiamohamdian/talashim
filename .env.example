NODE_ENV=development

# App
NEXT_PUBLIC_APP_NAME=طلاشیم
NEXT_PUBLIC_ADMIN_APP_NAME=Talashim Admin
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
# Comma-separated hostnames for next/image (e.g. cdn.example.com,zivazz.com)
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=
UPLOAD_PUBLIC_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000
NEXT_PUBLIC_GOLD_TRADE_COMMISSION_PERCENT=0.5

# API
API_PORT=4000
API_PREFIX=api
# Use `1` (Nest adds `v` → /api/v1). Do not set `v1` or routes become /api/vv1.
API_VERSION=1
# Local admin: auto-seed staff users + FAQ category on API start (set false in staging)
ADMIN_DEV_LOGIN=true
SWAGGER_ENABLED=
SWAGGER_PATH=docs
WEB_URL=http://localhost:3000
# Optional: bust storefront Next.js cache when CMS FAQ changes (same value in web + api .env)
# REVALIDATE_SECRET=replace-with-a-long-random-secret
ADMIN_URL=http://localhost:3002
COOKIE_DOMAIN=localhost
CORS_ORIGIN=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Database — use `sadaf_gold` if you already have a Docker volume from earlier dev setups
POSTGRES_DB=sadaf_gold
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sadaf_gold?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sadaf_gold?schema=public

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://localhost:6379

# Gold pricing (API + BrsApi live ticker)
# Free key: https://brsapi.ir/free-api-gold-currency-webservice/
# BrsApi requires a browser-like User-Agent (handled in @talashim/shared); blocked IPs clear after ~2h.
BRS_API_KEY=
BRS_API_URL=https://api.brsapi.ir/Market/Gold_Currency.php
GOLD_PRICE_PRIMARY_URL=
GOLD_PRICE_REFRESH_MS=30000
GOLD_PRICE_CACHE_TTL_SECONDS=60
GOLD_SPREAD_PERCENT=1.5
GOLD_TRADE_COMMISSION_PERCENT=0.5
GOLD_TRADE_MIN_GRAM=0.01

# Worker
WORKER_NAME=pricing-sync
WORKER_CONCURRENCY=5

# Auth
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-second-long-random-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Security & performance
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_TTL_MS=300000
HTTP_CACHE_TTL_SECONDS=60
COMPRESSION_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=false
LOG_LEVEL=log

# Nginx
NGINX_PORT=8080
NGINX_HTTP_PORT=80
