{
  "extends": "../tsconfig/library.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,
    "composite": true,
    "paths": {
      "@sadafgold/types": ["../types/dist/index"],
      "@sadafgold/types/*": ["../types/dist/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts"],
  "references": [{ "path": "../types" }]
}
